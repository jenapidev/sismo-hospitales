# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public Google Drive folder to mirror. No API key needed — the folder just has to
# be shared "anyone with the link".
DRIVE_ROOT_FOLDER_ID=1o36ifaRz45kAs5rKzci49aD0mP5JB_YI

# Comma-separated coordinator emails allowed into /admin
COORDINATOR_EMAILS=

# Image OCR (optional). Free Google AI Studio key. If unset, the OCR pass is skipped.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OCR_MAX_PER_RUN=30

# Optional: only needed to apply SQL migrations via scripts/apply-migrations.ts
# SUPABASE_DB_PASSWORD=
